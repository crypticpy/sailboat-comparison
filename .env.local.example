# Copy to .env.local for local dev (gitignored). In CI/Pages these come from
# GitHub repo secrets, injected at build time (see .github/workflows/deploy.yml).
#
# Both values are safe to expose in the client bundle: the project URL is public,
# and the anon/publishable key is meant for browsers — row-level security (see
# supabase/migrations) is what protects the data, not the key. NEVER put the
# service_role / secret key here or anywhere client-side.
#
# Leave these unset to run the app entirely off the bundled data/boats.json
# fallback (no backend needed).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
