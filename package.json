{
  "name": "sailboat-comparison",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive bluewater sailboat comparison — React + TypeScript + Supabase",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
